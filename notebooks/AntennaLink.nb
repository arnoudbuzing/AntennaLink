     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Segment Number\>\"", 
        ",", "\"\<Current Magnitude (A)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Dipole Current Distribution\>\""}]}], 
    "]"}], "\n"}]}]], "Input",
