Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "a", " ", "simple", " ", "dipole", " ", "antenna"}],
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"wires", "=", 
     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Segments\>\"", "->", "11"}], ",", 
        RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
        RowBox[{"\"\<P1\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", 
           RowBox[{"-", "0.25"}]}], "}"}]}], ",", 
        RowBox[{"\"\<P2\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0.25"}], "}"}]}], ",", 
        RowBox[{"\"\<Radius\>\"", "->", "0.001"}]}], "|>"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Set", " ", "frequency", " ", 
     RowBox[{"(", "MHz", ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"freq", "=", "299.79"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Add", " ", "excitation", " ", "to", " ", "the", " ", "center", " ", 
     "segment", " ", 
     RowBox[{"(", 
      RowBox[{"segment", " ", "6", " ", "of", " ", "11"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"excitations", "=", 
     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
        RowBox[{"\"\<Segment\>\"", "->", "6"}], ",", 
        RowBox[{"\"\<Voltage\>\"", "->", 
         RowBox[{"1.0", "+", 
          RowBox[{"0.0", "*", "I"}]}]}]}], "|>"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Run", " ", "the", " ", "solver", " ", "directly", " ", "in", " ", 
     "memory"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"AntennaSolveMemory", "[", 
      RowBox[{"wires", ",", "freq", ",", "excitations"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Query", " ", "the", " ", "computed", " ", "currents", " ", "Dataset"}], 
    "*)"}], "\n", 
   RowBox[{"results", "[", "\"\<Currents\>\"", "]"}]}]}]], "Input",
