Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"1.", " ", "Filter", " ", "out", " ", "the"}], "-", 
    RowBox[{"999.99", " ", "placeholder", " ", "values"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"validRP", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Normal", "[", "rp", "]"}], ",", 
       RowBox[{
        RowBox[{"#TotalGain", ">", 
         RowBox[{"-", "900"}]}], "&"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "2.", " ", "Calculate", " ", "a", " ", "40", "dB", " ", "dynamic", " ", 
      "range", " ", "to", " ", "create", " ", "deep"}], ",", 
     RowBox[{"visible", " ", "nulls"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxGain", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"validRP", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "\"\<TotalGain\>\""}], "]"}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"dynamicRange", "=", "40"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"minGainDisplay", "=", 
     RowBox[{"maxGain", "-", "dynamicRange"}]}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Map", " ", "to", " ", "Colatitude", " ", 
     RowBox[{"(", 
      RowBox[{"0", " ", "to", " ", "Pi"}], ")"}], " ", "and", " ", "Azimuth", 
     " ", 
     RowBox[{"(", 
      RowBox[{"0", " ", "to", " ", "2", "Pi"}], ")"}], " ", "for", " ", 
     "SphericalPlot3D"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"We", " ", "use", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"0", ",", 
       RowBox[{"Gain", "-", "minGainDisplay"}]}], "]"}], " ", "so", " ", 
     "the", " ", "weakest", " ", "signals", " ", "pull", " ", "all", " ", 
     "the", " ", "way", " ", "to", " ", "the", " ", "origin"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gainPoints", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Pi", "/", "2"}], "-", 
            RowBox[{"(", 
             RowBox[{"#Theta", "*", "Degree"}], ")"}]}], ",", 
           RowBox[{"#Phi", "*", "Degree"}]}], "}"}], ",", 
         RowBox[{"Max", "[", 
          RowBox[{"0", ",", 
           RowBox[{"#TotalGain", "-", "minGainDisplay"}]}], "]"}]}], "}"}], 
       "&"}], "/@", "validRP"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Create", " ", "an", " ", "interpolation", " ", "function", " ",
      "over", " ", "the", " ", "spherical", " ", "grid"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gainFunc", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"gainPoints", ",", 
       RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"5.", " ", "Render", " ", "a", " ", "solid"}], ",", 
     RowBox[{"colorful", " ", "3", "D", " ", 
      RowBox[{"lobe", "!"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"SphericalPlot3D", "[", 
    RowBox[{
     RowBox[{"gainFunc", "[", 
      RowBox[{"colat", ",", "az"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"colat", ",", "0", ",", "Pi"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"az", ",", "0", ",", 
