    RowBox[{"Export", "[", 
     RowBox[{
     "necFile", 
      ",", "\"\<CM Simple Dipole\nCE\nGW 1 11 0 0 -0.25 0 0 0.25 0.001\nGE 0\n\
EX 0 1 6 0 1.0 0.0\nFR 0 1 0 0 299.79 0\nXQ\nEN\n\>\"", 
      ",", "\"\<String\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
