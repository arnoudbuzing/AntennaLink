  RowBox[{
   RowBox[{
    RowBox[{"necFile", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"$TemporaryDirectory", ",", "\"\<dipole.nec\>\""}], "}"}], 
      "]"}]}], ";"}], "\n", 
