Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Extract", " ", 
    RowBox[{"{", 
     RowBox[{"X", ",", "Y", ",", "Z"}], "}"}], " ", "coordinates", " ", "and",
     " ", "compute", " ", "Current", " ", "Magnitude"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"data3D", "=", 
     RowBox[{"Normal", "[", 
      RowBox[{
       RowBox[{"results", "[", "\"\<Currents\>\"", "]"}], "[", 
       RowBox[{"All", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"#X", ",", "#Y", ",", "#Z"}], "}"}], "->", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"#CurrentReal", "^", "2"}], "+", 
            RowBox[{"#CurrentImag", "^", "2"}]}], "]"}]}], "&"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Create", " ", "a", " ", "3", "D", " ", "plot", " ", "where", " ", 
     "point", " ", "color", " ", "represents", " ", "the", " ", "current", " ",
      "magnitude"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListPointPlot3D", "[", 
    RowBox[{"data3D", ",", 
     RowBox[{"ColorFunction", "->", "\"\<Rainbow\>\""}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"PointSize", "[", "0.05", "]"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}], ",", 
     RowBox[{"BoxRatios", "->", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "3"}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<3D Current Distribution\>\""}]}], 
    "]"}]}]}]], "Input",
