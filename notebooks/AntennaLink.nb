Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Helix", " ", "aligned", " ", "along", " ", "the", " ", "Z"}], "-",
     "axis"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"helixWires", "=", 
    RowBox[{"AntennaHelix", "[", 
     RowBox[{"0.08", ",", 
      RowBox[{"(*", 
       RowBox[{"Coil", " ", "radius"}], "*)"}], "0.10", ",", 
      RowBox[{"(*", 
       RowBox[{"Turn", " ", "pitch"}], "*)"}], "5.0", ",", 
      RowBox[{"(*", 
       RowBox[{"Number", " ", "of", " ", "turns"}], "*)"}], "0.001", ",", 
      RowBox[{"(*", 
       RowBox[{"Wire", " ", "radius"}], "*)"}], "16"}], "     ", 
     RowBox[{"(*", 
      RowBox[{"Segments", " ", "per", " ", "turn"}], "*)"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.9900264377870197`*^9, 3.990026461150941*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"f5c1ef07-ed96-460a-94ef-481630db04fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Solve", " ", "helical", " ", "antenna"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"sol", "=", 
    RowBox[{"AntennaSolveMemory", "[", 
     RowBox[{"helixWires", ",", "300.0", ",", 
      RowBox[{"{", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
         RowBox[{"\"\<Segment\>\"", "->", "1"}], ",", 
         RowBox[{"\"\<Voltage\>\"", "->", "1.0"}]}], "|>"}], "}"}]}], "]"}]}],
    ";"}]}]], "Input",
