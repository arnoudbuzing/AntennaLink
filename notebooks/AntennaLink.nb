     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Tag\>\"", "->", "2"}], ",", 
        RowBox[{"\"\<Segment\>\"", "->", "6"}], ",", 
        RowBox[{"\"\<Voltage\>\"", "->", 
         RowBox[{"1.0", "+", 
