Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Parse", " ", "results", " ", "from", " ", "a", " ", "simulation", " ", 
    "that", " ", "included", " ", "an", " ", "RP", " ", "card"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"AntennaParseOutput", "[", "outFile", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rp", "=", 
     RowBox[{"results", "[", "\"\<RadiationPattern\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Filter", " ", "out", " ", "placeholder", " ", "values", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"NEC", " ", "uses"}], "-", 
       RowBox[{"999.99", " ", "for", " ", "undefined", " ", "gains"}]}], 
      ")"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "And", " ", "shift", " ", "the", " ", "gain", " ", "to", " ", "be", " ", 
     "positive", " ", "for", " ", "the", " ", "radius", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"e", ".", "g", "."}], ",", 
       RowBox[{"if", " ", "max", " ", "gain", " ", "is", " ", "2.17"}], ",", 
       RowBox[{"add", " ", "offset"}]}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"minGain", "=", 
     RowBox[{"Min", "[", 
      RowBox[{"Normal", "[", 
       RowBox[{"rp", "[", 
        RowBox[{"All", ",", 
         RowBox[{"#TotalGain", "&"}]}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"offset", "=", 
     RowBox[{
      RowBox[{"Abs", "[", "minGain", "]"}], "+", "1"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Convert", " ", "Spherical", " ", 
     RowBox[{"(", 
      RowBox[{"Theta", ",", "Phi"}], ")"}], " ", "and", " ", "Gain", " ", 
     RowBox[{"(", "Radius", ")"}], " ", "to", " ", "Cartesian", " ", 
     RowBox[{"{", 
      RowBox[{"X", ",", "Y", ",", "Z"}], "}"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Note", ":", 
     RowBox[{"NEC", "-", 
      RowBox[{
      "2", " ", "Theta", " ", "is", " ", "often", " ", "elevation", " ", 
       "from", " ", "the", " ", "XY", " ", "plane", " ", "depending", " ", 
       "on", " ", "RP", " ", "card", " ", "config"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"points3D", "=", 
     RowBox[{"Normal", "[", 
      RowBox[{"rp", "[", 
       RowBox[{"All", ",", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"r", "=", 
              RowBox[{"#TotalGain", "+", "offset"}]}], ",", 
             RowBox[{"th", "=", 
              RowBox[{"#Theta", "*", "Degree"}]}], ",", 
             RowBox[{"ph", "=", 
              RowBox[{"#Phi", "*", "Degree"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"r", "*", 
              RowBox[{"Cos", "[", "th", "]"}], "*", 
              RowBox[{"Cos", "[", "ph", "]"}]}], ",", 
             RowBox[{"r", "*", 
              RowBox[{"Cos", "[", "th", "]"}], "*", 
              RowBox[{"Sin", "[", "ph", "]"}]}], ",", 
             RowBox[{"r", "*", 
              RowBox[{"Sin", "[", "th", "]"}]}]}], "}"}]}], "]"}], "&"}]}], 
       "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Create", " ", "a", " ", "3", "D", " ", "Point", " ", "Plot", " ", 
      "colored", " ", "by", " ", "Z"}], "-", 
     RowBox[{"height", " ", 
      RowBox[{"(", 
       RowBox[{"or", " ", "Gain"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"ListPointPlot3D", "[", 
    RowBox[{"points3D", ",", 
     RowBox[{"ColorFunction", "->", "\"\<Rainbow\>\""}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"PointSize", "[", "0.02", "]"}]}], ",", 
     RowBox[{"BoxRatios", "->", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<3D Radiation Pattern\>\""}]}], 
    "]"}]}]}]], "Input",
