Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "current", " ", "magnitudes", " ", "from", " ", "Real", " ",
     "and", " ", "Imaginary", " ", "parts"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"magnitudes", "=", 
     RowBox[{"Normal", "[", 
      RowBox[{
       RowBox[{"results", "[", "\"\<Currents\>\"", "]"}], "[", 
       RowBox[{"All", ",", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"#CurrentReal", "^", "2"}], "+", 
           RowBox[{"#CurrentImag", "^", "2"}]}], "]"}], "&"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Plot", " ", "the", " ", "2", "D", " ", "current", " ", "distribution", " ",
      "along", " ", "the", " ", "wire"}], "*)"}], "\n", 
   RowBox[{"ListLinePlot", "[", 
