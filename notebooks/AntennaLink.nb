Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Define", " ", "the", " ", "elements", " ", "of", " ", "the", " ", 
     "Yagi"}], "-", 
    RowBox[{"Uda", " ", "Antenna"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"wires", "=", 
     RowBox[{"{", 
      RowBox[{"(*", 
       RowBox[{"1.", " ", "Reflector", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Longer", " ", "than", " ", "dipole"}], ",", 
          RowBox[{"placed", " ", "behind", " ", "it"}]}], ")"}]}], "*)"}], 
      RowBox[{
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Segments\>\"", "->", "11"}], ",", 
         RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
         RowBox[{"\"\<P1\>\"", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.25"}], ",", "0", ",", 
            RowBox[{"-", "0.2625"}]}], "}"}]}], ",", 
         RowBox[{"\"\<P2\>\"", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.25"}], ",", "0", ",", "0.2625"}], "}"}]}], ",", 
         RowBox[{"\"\<Radius\>\"", "->", "0.001"}]}], "|>"}], ",", 
       RowBox[{"(*", 
        RowBox[{"2.", " ", "Driven", " ", "Element", " ", 
         RowBox[{"(", 
          RowBox[{"The", " ", "actual", " ", "dipole"}], ")"}]}], "*)"}], 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Segments\>\"", "->", "11"}], ",", 
         RowBox[{"\"\<Tag\>\"", "->", "2"}], ",", 
         RowBox[{"\"\<P1\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{"-", "0.2375"}]}], "}"}]}], ",", 
         RowBox[{"\"\<P2\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0.2375"}], "}"}]}], ",", 
         RowBox[{"\"\<Radius\>\"", "->", "0.001"}]}], "|>"}], ",", 
       RowBox[{"(*", 
        RowBox[{"3.", " ", "Director", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Shorter", " ", "than", " ", "dipole"}], ",", 
           RowBox[{
           "placed", " ", "in", " ", "front", " ", "of", " ", "it"}]}], 
          ")"}]}], "*)"}], 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Segments\>\"", "->", "11"}], ",", 
         RowBox[{"\"\<Tag\>\"", "->", "3"}], ",", 
         RowBox[{"\"\<P1\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"0.25", ",", "0", ",", 
            RowBox[{"-", "0.225"}]}], "}"}]}], ",", 
         RowBox[{"\"\<P2\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"0.25", ",", "0", ",", "0.225"}], "}"}]}], ",", 
         RowBox[{"\"\<Radius\>\"", "->", "0.001"}]}], "|>"}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Frequency", " ", "in", " ", "MHz"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"freq", "=", "299.79"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Excitation", " ", "is", " ", "ONLY", " ", "applied", " ", "to", " ", 
     "the", " ", "center", " ", 
     RowBox[{"(", 
      RowBox[{"Segment", " ", "6"}], ")"}], " ", "of", " ", "the", " ", 
