Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Quarter", "-", 
    RowBox[{
    "wave", " ", "monopole", " ", "on", " ", "Sommerfeld", " ", "ground"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"monopole", "=", 
     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Segments\>\"", "->", "5"}], ",", 
        RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
        RowBox[{"\"\<P1\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], ",", 
        RowBox[{"\"\<P2\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0.25"}], "}"}]}], ",", 
        RowBox[{"\"\<Radius\>\"", "->", "0.001"}]}], "|>"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"baseFeed", "=", 
     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Tag\>\"", "->", "1"}], ",", 
        RowBox[{"\"\<Segment\>\"", "->", "1"}], ",", 
        RowBox[{"\"\<Voltage\>\"", "->", "1.0"}]}], "|>"}], "}"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Solve", " ", "over", " ", "lossy", " ", "earth", " ", "using", " ", 
     "Sommerfeld", " ", "method"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solSommerfeld", "=", 
     RowBox[{"AntennaSolveMemory", "[", 
      RowBox[{"monopole", ",", "299.79", ",", "baseFeed", ",", 
       RowBox[{"\"\<Ground\>\"", "->", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Type\>\"", "->", "\"\<Sommerfeld\>\""}], ",", 
          RowBox[{"\"\<Dielectric\>\"", "->", "15.0"}], ",", 
          RowBox[{"\"\<Conductivity\>\"", "->", "0.01"}], ",", 
          RowBox[{"\"\<ConnectWires\>\"", "->", "True"}]}], "|>"}]}]}], 
      "]"}]}], ";"}]}]}]], "Input",
